{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kotekomi.local/schemas/task-manifest-v1.schema.json",
  "title": "KoteKomi Task Manifest V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "title",
    "status",
    "series_id",
    "task_class",
    "model_profile",
    "baseline_revision",
    "tdd_path",
    "tdd_sha256",
    "goal",
    "depends_on",
    "allowed_paths",
    "reference_paths",
    "protected_artifacts",
    "acceptance",
    "readiness",
    "budget",
    "stop_conditions"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "task_id": {
      "$ref": "#/$defs/identifier"
    },
    "title": {
      "$ref": "#/$defs/non_empty_text"
    },
    "status": {
      "type": "string",
      "const": "ready_for_terra_high"
    },
    "series_id": {
      "$ref": "#/$defs/identifier"
    },
    "task_class": {
      "type": "string",
      "enum": [
        "schema-contract",
        "pure-behavior",
        "move-only-refactor",
        "adapter-contract",
        "orchestration",
        "wiring",
        "repository-tooling",
        "documentation-contract"
      ]
    },
    "model_profile": {
      "type": "string",
      "const": "terra-high-v1"
    },
    "baseline_revision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "tdd_path": {
      "$ref": "#/$defs/repository_path"
    },
    "tdd_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "goal": {
      "$ref": "#/$defs/non_empty_text"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/identifier"
      },
      "uniqueItems": true
    },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/repository_path"
      }
    },
    "reference_paths": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repository_path"
      }
    },
    "protected_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/protected_artifact"
      }
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/acceptance_command"
      }
    },
    "readiness": {
      "$ref": "#/$defs/readiness"
    },
    "budget": {
      "$ref": "#/$defs/budget"
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_text"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "non_empty_text": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "repository_path": {
      "type": "string",
      "minLength": 1
    },
    "protected_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "kind"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/repository_path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "kind": {
          "type": "string",
          "enum": [
            "leaf-tdd",
            "task-manifest",
            "json-schema",
            "acceptance-test",
            "fixture",
            "golden",
            "agent-instructions"
          ]
        }
      }
    },
    "acceptance_command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "argv",
        "timeout_seconds",
        "profile"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "profile": {
          "type": "string",
          "enum": [
            "portable-local",
            "authoritative-linux",
            "private-conformance"
          ]
        }
      }
    },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dominant_outcome",
        "contract_family",
        "public_entry_point",
        "authority",
        "scope_policy",
        "side_effect_boundary",
        "failure_policy",
        "negative_proof",
        "legacy_disposition",
        "unresolved_decisions"
      ],
      "properties": {
        "dominant_outcome": {
          "$ref": "#/$defs/non_empty_text"
        },
        "contract_family": {
          "$ref": "#/$defs/identifier"
        },
        "public_entry_point": {
          "$ref": "#/$defs/non_empty_text"
        },
        "authority": {
          "$ref": "#/$defs/non_empty_text"
        },
        "scope_policy": {
          "$ref": "#/$defs/non_empty_text"
        },
        "side_effect_boundary": {
          "$ref": "#/$defs/non_empty_text"
        },
        "failure_policy": {
          "$ref": "#/$defs/non_empty_text"
        },
        "negative_proof": {
          "$ref": "#/$defs/non_empty_text"
        },
        "legacy_disposition": {
          "$ref": "#/$defs/non_empty_text"
        },
        "unresolved_decisions": {
          "type": "array",
          "maxItems": 0,
          "items": {
            "$ref": "#/$defs/non_empty_text"
          }
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maximum_production_files",
        "maximum_test_files",
        "maximum_production_diff_lines"
      ],
      "properties": {
        "maximum_production_files": {
          "type": "integer",
          "minimum": 1
        },
        "maximum_test_files": {
          "type": "integer",
          "minimum": 1
        },
        "maximum_production_diff_lines": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
