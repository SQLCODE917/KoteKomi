{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "id": {
      "pattern": "^pat_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Id",
      "type": "string"
    },
    "initiator": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Initiator"
    },
    "invocation_id": {
      "minLength": 1,
      "title": "Invocation Id",
      "type": "string"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "task_fingerprint_id": {
      "pattern": "^ptf_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Task Fingerprint Id",
      "type": "string"
    }
  },
  "required": [
    "id",
    "task_fingerprint_id",
    "started_at",
    "invocation_id"
  ],
  "title": "ProcessingAttempt",
  "type": "object"
}
