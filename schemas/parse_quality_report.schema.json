{
  "$defs": {
    "JsonValue": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ]
    },
    "RepresentationAnalyzability": {
      "enum": [
        "acceptable",
        "degraded",
        "blocked"
      ],
      "title": "RepresentationAnalyzability",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "analyzability": {
      "$ref": "#/$defs/RepresentationAnalyzability"
    },
    "id": {
      "pattern": "^pqr_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Id",
      "type": "string"
    },
    "issues": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Issues",
      "type": "array"
    },
    "metric_values": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "title": "Metric Values",
      "type": "object"
    },
    "representation_id": {
      "pattern": "^rep_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Representation Id",
      "type": "string"
    }
  },
  "required": [
    "id",
    "representation_id",
    "analyzability"
  ],
  "title": "ParseQualityReport",
  "type": "object"
}
