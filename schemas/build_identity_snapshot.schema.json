{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_digest": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Artifact Digest",
      "type": "string"
    },
    "package_version": {
      "minLength": 1,
      "title": "Package Version",
      "type": "string"
    },
    "representation_policy_version": {
      "minLength": 1,
      "title": "Representation Policy Version",
      "type": "string"
    },
    "source_revision": {
      "minLength": 1,
      "title": "Source Revision",
      "type": "string"
    }
  },
  "required": [
    "package_version",
    "source_revision",
    "artifact_digest",
    "representation_policy_version"
  ],
  "title": "BuildIdentitySnapshot",
  "type": "object"
}
