{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "canonical_output_digest": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Canonical Output Digest",
      "type": "string"
    },
    "code_revision": {
      "minLength": 1,
      "title": "Code Revision",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "document_id": {
      "pattern": "^doc_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Document Id",
      "type": "string"
    },
    "id": {
      "pattern": "^rep_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Id",
      "type": "string"
    },
    "input_blob_digest": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Input Blob Digest",
      "type": "string"
    },
    "parser_config_digest": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Parser Config Digest",
      "type": "string"
    },
    "parser_name": {
      "minLength": 1,
      "title": "Parser Name",
      "type": "string"
    },
    "parser_version": {
      "minLength": 1,
      "title": "Parser Version",
      "type": "string"
    }
  },
  "required": [
    "id",
    "document_id",
    "parser_name",
    "parser_version",
    "parser_config_digest",
    "code_revision",
    "input_blob_digest",
    "canonical_output_digest"
  ],
  "title": "DocumentRepresentation",
  "type": "object"
}
