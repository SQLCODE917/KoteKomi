{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "continued_from_fragment_id": {
      "anyOf": [
        {
          "pattern": "^tfr_[A-Za-z0-9][A-Za-z0-9_-]*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Continued From Fragment Id"
    },
    "fragment_index": {
      "minimum": 0,
      "title": "Fragment Index",
      "type": "integer"
    },
    "id": {
      "pattern": "^tfr_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Id",
      "type": "string"
    },
    "page_numbers": {
      "items": {
        "minimum": 1,
        "type": "integer"
      },
      "title": "Page Numbers",
      "type": "array"
    },
    "repeated_header_cell_ids": {
      "items": {
        "pattern": "^tcl_[A-Za-z0-9][A-Za-z0-9_-]*$",
        "type": "string"
      },
      "title": "Repeated Header Cell Ids",
      "type": "array"
    },
    "representation_id": {
      "pattern": "^rep_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Representation Id",
      "type": "string"
    },
    "source_region_ids": {
      "items": {
        "pattern": "^srg_[A-Za-z0-9][A-Za-z0-9_-]*$",
        "type": "string"
      },
      "title": "Source Region Ids",
      "type": "array"
    },
    "table_id": {
      "pattern": "^tbl_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Table Id",
      "type": "string"
    }
  },
  "required": [
    "id",
    "representation_id",
    "table_id",
    "fragment_index",
    "page_numbers",
    "source_region_ids"
  ],
  "title": "DocumentTableFragment",
  "type": "object"
}
