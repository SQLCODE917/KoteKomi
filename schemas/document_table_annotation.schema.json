{
  "$defs": {
    "TableAnnotationKind": {
      "enum": [
        "caption",
        "unit",
        "note"
      ],
      "title": "TableAnnotationKind",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "fragment_id": {
      "anyOf": [
        {
          "pattern": "^tfr_[A-Za-z0-9][A-Za-z0-9_-]*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fragment Id"
    },
    "id": {
      "pattern": "^tan_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Id",
      "type": "string"
    },
    "kind": {
      "$ref": "#/$defs/TableAnnotationKind"
    },
    "node_id": {
      "pattern": "^nod_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Node Id",
      "type": "string"
    },
    "representation_id": {
      "pattern": "^rep_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Representation Id",
      "type": "string"
    },
    "source_region_ids": {
      "items": {
        "pattern": "^srg_[A-Za-z0-9][A-Za-z0-9_-]*$",
        "type": "string"
      },
      "title": "Source Region Ids",
      "type": "array"
    },
    "table_id": {
      "pattern": "^tbl_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Table Id",
      "type": "string"
    }
  },
  "required": [
    "id",
    "representation_id",
    "table_id",
    "kind",
    "node_id",
    "source_region_ids"
  ],
  "title": "DocumentTableAnnotation",
  "type": "object"
}
