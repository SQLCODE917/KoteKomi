{
  "$defs": {
    "SourceType": {
      "enum": [
        "article",
        "transcript",
        "pdf",
        "blog_post",
        "social_post",
        "filing",
        "press_release",
        "manual_file"
      ],
      "title": "SourceType",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "canonical_identity_key": {
      "minLength": 1,
      "title": "Canonical Identity Key",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "id": {
      "pattern": "^src_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Id",
      "type": "string"
    },
    "identity_policy_id": {
      "minLength": 1,
      "title": "Identity Policy Id",
      "type": "string"
    },
    "provider_item_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Provider Item Id"
    },
    "provider_namespace": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Provider Namespace"
    },
    "source_type": {
      "$ref": "#/$defs/SourceType"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "id",
    "source_type",
    "identity_policy_id",
    "canonical_identity_key"
  ],
  "title": "Source",
  "type": "object"
}
