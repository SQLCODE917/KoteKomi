{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "extraction_task_id": {
      "pattern": "^ext_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Extraction Task Id",
      "type": "string"
    },
    "id": {
      "pattern": "^ats_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Id",
      "type": "string"
    },
    "planned_item_id": {
      "pattern": "^pai_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Planned Item Id",
      "type": "string"
    },
    "selection_role": {
      "minLength": 1,
      "title": "Selection Role",
      "type": "string"
    }
  },
  "required": [
    "id",
    "planned_item_id",
    "extraction_task_id",
    "selection_role"
  ],
  "title": "AnalysisItemTaskSelection",
  "type": "object"
}
