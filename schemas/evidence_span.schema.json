{
  "$defs": {
    "EvidenceValidationStatus": {
      "enum": [
        "legacy_unvalidated",
        "validated",
        "failed"
      ],
      "title": "EvidenceValidationStatus",
      "type": "string"
    },
    "JsonValue": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ]
    },
    "SelectorType": {
      "enum": [
        "exact_text",
        "text_position",
        "page"
      ],
      "title": "SelectorType",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "assertion_id": {
      "anyOf": [
        {
          "pattern": "^ast_[A-Za-z0-9][A-Za-z0-9_-]*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Assertion Id"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "document_id": {
      "pattern": "^doc_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Document Id",
      "type": "string"
    },
    "dom_selector": {
      "anyOf": [
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Dom Selector"
    },
    "end_char": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "End Char"
    },
    "exact_text": {
      "minLength": 1,
      "title": "Exact Text",
      "type": "string"
    },
    "id": {
      "pattern": "^evs_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Id",
      "type": "string"
    },
    "location": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "title": "Location",
      "type": "object"
    },
    "node_ids": {
      "items": {
        "pattern": "^nod_[A-Za-z0-9][A-Za-z0-9_-]*$",
        "type": "string"
      },
      "title": "Node Ids",
      "type": "array"
    },
    "pdf_region_ids": {
      "items": {
        "pattern": "^srg_[A-Za-z0-9][A-Za-z0-9_-]*$",
        "type": "string"
      },
      "title": "Pdf Region Ids",
      "type": "array"
    },
    "prefix_text": {
      "default": "",
      "title": "Prefix Text",
      "type": "string"
    },
    "representation_id": {
      "anyOf": [
        {
          "pattern": "^rep_[A-Za-z0-9][A-Za-z0-9_-]*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Representation Id"
    },
    "selector_normalization_policy": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Selector Normalization Policy"
    },
    "selector_type": {
      "$ref": "#/$defs/SelectorType"
    },
    "source_id": {
      "pattern": "^src_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Source Id",
      "type": "string"
    },
    "start_char": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Start Char"
    },
    "suffix_text": {
      "default": "",
      "title": "Suffix Text",
      "type": "string"
    },
    "table_selector": {
      "anyOf": [
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Table Selector"
    },
    "target_digest": {
      "anyOf": [
        {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Target Digest"
    },
    "text_view_digest": {
      "anyOf": [
        {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Text View Digest"
    },
    "text_view_id": {
      "anyOf": [
        {
          "pattern": "^tvw_[A-Za-z0-9][A-Za-z0-9_-]*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Text View Id"
    },
    "validated_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Validated At"
    },
    "validation_status": {
      "$ref": "#/$defs/EvidenceValidationStatus",
      "default": "legacy_unvalidated"
    },
    "validator_version": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Validator Version"
    }
  },
  "required": [
    "id",
    "source_id",
    "document_id",
    "selector_type",
    "exact_text"
  ],
  "title": "EvidenceSpan",
  "type": "object"
}
