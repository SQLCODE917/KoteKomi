{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "context_manifest_id": {
      "pattern": "^ctx_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Context Manifest Id",
      "type": "string"
    },
    "id": {
      "pattern": "^ams_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Id",
      "type": "string"
    },
    "planned_item_id": {
      "pattern": "^pai_[A-Za-z0-9][A-Za-z0-9_-]*$",
      "title": "Planned Item Id",
      "type": "string"
    },
    "selection_role": {
      "minLength": 1,
      "title": "Selection Role",
      "type": "string"
    }
  },
  "required": [
    "id",
    "planned_item_id",
    "context_manifest_id",
    "selection_role"
  ],
  "title": "AnalysisItemManifestSelection",
  "type": "object"
}
